<table
  role='presentation'
  cellpadding='0'
  cellspacing='0'
  width='100%'
  style='background-color: #f3f5f4; margin: 0; padding: 24px 12px; font-family: Arial, Helvetica, sans-serif;'
>
  <tr>
    <td align='center'>
      <table
        role='presentation'
        cellpadding='0'
        cellspacing='0'
        width='100%'
        style='max-width: 620px; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #d9e6dc;'
      >
        <tr>
          <td
            style='background: linear-gradient(90deg, #66b529 0%, #7fcc3a 100%); padding: 24px; color: #ffffff;'
          >
            <h1
              style='margin: 0; font-size: 24px; line-height: 30px; font-weight: 700;'
            >Detalles del hallazgo #{{id}}</h1>
            <p style='margin: 8px 0 0 0; font-size: 14px; line-height: 20px;'>
              Se ha registrado un nuevo hallazgo.
            </p>
          </td>
        </tr>

        <tr>
          <td style='padding: 24px; color: #233129;'>
            <table
              role='presentation'
              cellpadding='0'
              cellspacing='0'
              width='100%'
              style='background-color: #f8fbf6; border: 1px solid #d9e6dc; border-radius: 8px;'
            >
              <tr>
                <td
                  style='padding: 14px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>Planta:</strong>
                  {{manufacturingPlant}}
                </td>
              </tr>
              <tr>
                <td
                  style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>{{mainType}}:</strong>
                  {{secondaryType}}
                </td>
              </tr>
              <tr>
                <td
                  style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>Lugar:</strong>
                  {{zone}}
                </td>
              </tr>

              {{#if descripcion}}
                <tr>
                  <td
                    style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                  >
                    <strong>Descripción del comportamiento inseguro:</strong>
                    {{descripcion}}
                  </td>
                </tr>
              {{/if}}

              <tr>
                <td
                  style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>Creado por:</strong>
                  {{userWhoCreated}}
                </td>
              </tr>
              <tr>
                <td
                  style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>Supervisores:</strong>
                  {{supervisor}}
                </td>
              </tr>
              {{#if priorityLabel}}
                <tr>
                  <td
                    style='padding: 0 16px 14px 16px; font-size: 14px; line-height: 22px;'
                  >
                    <strong>Prioridad:</strong>
                    {{priorityLabel}}
                  </td>
                </tr>
              {{/if}}
              <tr>
                <td
                  style='padding: 0 16px 16px 16px; font-size: 14px; line-height: 22px;'
                >
                  <strong>Fecha de creación:</strong>
                  {{createdAt}}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style='padding: 0 24px 20px 24px;'>
            <p
              style='margin: 0 0 10px 0; font-size: 14px; line-height: 22px; color: #233129; font-weight: 700;'
            >Hallazgo</p>
            <img
              src='cid:imgEvidence'
              alt='Imagen del hallazgo'
              style='width: 100%; max-width: 520px; height: auto; border-radius: 8px; border: 1px solid #d9e6dc; display: block;'
            />
          </td>
        </tr>

        <tr>
          <td style='padding: 0 24px 20px 24px;'>
            <table
              role='presentation'
              cellpadding='0'
              cellspacing='0'
              width='100%'
              style='background-color: #eef7e8; border-radius: 8px;'
            >
              <tr>
                <td
                  style='padding: 14px 16px; font-size: 12px; line-height: 18px; color: #415448;'
                >
                  Este correo fue generado automaticamente por el sistema
                  ComportArte. Por favor, no respondas a este mensaje.
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td align='center' style='padding: 8px 24px 24px 24px;'>
            <img
              src='https://api.comportarte.com/static/images/login/logo-inferior.png'
              alt='ComportArte'
              style='max-width: 260px; width: 100%; height: auto; border: 0; display: block;'
            />
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>